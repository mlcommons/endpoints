# Development Dockerfile for the MLPerf Inference Endpoint Benchmarking System
# From project root:
# docker build -f scripts/Dockerfile.dev --build-arg USER_ID=$(id -u) --build-arg GROUP_ID=$(id -g) -t inference-endpoint-dev .
# docker run -e HF_TOKEN=$HF_TOKEN --net host --gpus all -v $(pwd):/mnt/inference-endpoint -it --shm-size=1024m inference-endpoint-dev bash

FROM python:3.12-slim

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HF_TOKEN=${HF_TOKEN}

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential procps git sudo \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir /mnt/inference-endpoint
WORKDIR /mnt/inference-endpoint
COPY requirements/ ./requirements/
COPY pyproject.toml .
COPY src/ ./src/
COPY examples/ ./examples/

# Create a non-root user for security
# Accept UID and GID as build arguments to match host user
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN if ! getent group ${GROUP_ID}; then \
        groupadd -g ${GROUP_ID} appuser; \
    fi && \
    useradd -u ${USER_ID} -g ${GROUP_ID} --create-home --shell /bin/bash appuser --no-log-init && \
    chown -R ${USER_ID}:${GROUP_ID} /mnt/inference-endpoint
USER appuser
ENV PATH="/home/appuser/.local/bin:$PATH"

# Grant passwordless sudo access to appuser
USER root
RUN echo "appuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
USER appuser

RUN pip install --no-cache-dir -r requirements/base.txt -r requirements/test.txt
RUN pip install -e .
RUN sudo bash /mnt/inference-endpoint/examples/07_GPT-OSS-120B_SGLang_Example/setup_lcb.sh
# RUN sudo bash /mnt/inference-endpoint/examples/07_GPT-OSS-120B_SGLang_Example/setup_lcb.sh
