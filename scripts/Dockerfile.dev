# Development Dockerfile for the MLPerf Inference Endpoint Benchmarking System
# From project root:
# docker build -f scripts/Dockerfile.dev --build-arg USER_ID=$(id -u) --build-arg GROUP_ID=$(id -g) -t inference-endpoint-dev .
# docker run -v $(pwd):/mnt/inference-endpoint -it --shm-size=512m inference-endpoint-dev bash

FROM python:3.12.11-slim

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:0.7.6 /uv /uvx /bin/

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv

# Install system dependencies
# git + curl + ca-certificates are required by the deepseek_r1 evaluator's setup_eval.sh
# (git-clones prm800k / LiveCodeBench and curls the MLCommons eval_accuracy.py) in the
# provisioning RUN below; without them that step fails and mlperf_eval/ is never baked.
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential procps git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir /mnt/inference-endpoint
WORKDIR /mnt/inference-endpoint

# Copy lockfile + project metadata for dependency layer caching
COPY pyproject.toml uv.lock .python-version README.md ./

# Create a non-root user for security
# Accept UID and GID as build arguments to match host user
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN if ! getent group ${GROUP_ID}; then \
        groupadd -g ${GROUP_ID} appuser; \
    fi && \
    useradd -u ${USER_ID} -g ${GROUP_ID} --create-home --shell /bin/bash appuser --no-log-init && \
    chown -R ${USER_ID}:${GROUP_ID} /mnt/inference-endpoint && \
    mkdir -p /opt/venv && chown ${USER_ID}:${GROUP_ID} /opt/venv
USER appuser
ENV PATH="/opt/venv/bin:/home/appuser/.local/bin:$PATH"

# Install dependencies first (cached unless pyproject.toml/uv.lock change)
RUN uv sync --frozen --no-install-project --extra dev --extra test

# Copy source and install project
COPY --chown=${USER_ID}:${GROUP_ID} src/ ./src/
RUN uv sync --frozen --extra dev --extra test


# Provision the isolated DeepSeek-R1 accuracy evaluator so the image is self-contained for
# `inference-endpoint benchmark --mode acc|both` with NO host checkout and NO runtime network.
# DeepSeekR1Scorer shells out via `uv run --project src/inference_endpoint/evaluation/deepseek_r1`;
# that subproject pins heavy/conflicting deps (transformers, prm800k, LiveCodeBench code
# executor) that must stay OUT of /opt/venv. So override UV_PROJECT_ENVIRONMENT to build the
# subproject's OWN .venv, then setup_eval.sh fetches eval_accuracy.py + prm800k + LiveCodeBench
# into mlperf_eval/. (At run time the launcher must likewise point UV_PROJECT_ENVIRONMENT +
# DEEPSEEK_EVAL_PROJECT_PATH at this subproject, since the image ENV defaults to /opt/venv.)
RUN cd src/inference_endpoint/evaluation/deepseek_r1 && \
    UV_PROJECT_ENVIRONMENT="$(pwd)/.venv" uv sync && \
    UV_PROJECT_ENVIRONMENT="$(pwd)/.venv" bash setup_eval.sh
